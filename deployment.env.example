# Deployment .env template for ShareLand

# VPS/Server
VPS_IP=your.vps.ip.address
VPS_USER=your_vps_user
VPS_PASSWORD=your_vps_password
DOMAIN=shareland.it

# Database
DB_NAME=Open_Landscapes
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Django/Email
SECRET_KEY=your-secret-key
DEBUG=False
ALLOWED_HOSTS=shareland.it,localhost
DEFAULT_FROM_EMAIL=no-replay@shareland.it
ADMIN_EMAIL=admin@shareland.it
EMAIL_HOST=smtps.aruba.it
EMAIL_PORT=465
EMAIL_HOST_USER=no-replay@shareland.it
EMAIL_HOST_PASSWORD=Shar3land@2025
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True

# Google Drive Backup
GDRIVE_FOLDER_ID=your_gdrive_folder_id

